{
  "$schema": "vscode://schemas/color-theme",
  "name": "Dark Bruv",
  "type": "dark",
  "include": "./dark_vs.json",
  "semanticHighlighting": true,

  "semanticTokenColors": {
    "type":                { "foreground": "#56d4e8" },
    "interface":           { "foreground": "#56d4e8" },
    "class":               { "foreground": "#56d4e8" },
    "enum":                { "foreground": "#56d4e8" },
    "typeParameter":       { "foreground": "#56d4e8" },
    "function":            { "foreground": "#fa57d7", "fontStyle": "italic" },
    "method":              { "foreground": "#fa57d7", "fontStyle": "italic" },
    "variable":            { "foreground": "#fcf948" },
    "parameter":           { "foreground": "#fcf948" },
    "property":            { "foreground": "#cdd6f4" },
    "enumMember":          { "foreground": "#569cd6" },
    "decorator":           { "foreground": "#d7ba7d" },
    "namespace":           { "foreground": "#b791ff" },
    "keyword":             { "foreground": "#fa57d7" },
    "variable.readonly":   { "foreground": "#569cd6" },
    "property.readonly":   { "foreground": "#569cd6" },
    "variable.static":     { "foreground": "#fcf948", "fontStyle": "underline" }
  },

  "tokenColors": [

    // ─── Comments ────────────────────────────────────────────────────────────
    {
      "name": "Comments",
      "scope": ["comment.line", "comment.block", "comment"],
      "settings": { "foreground": "#6a7a8a", "fontStyle": "italic" }
    },

    // ─── Keywords ────────────────────────────────────────────────────────────
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "keyword.operator.delete",
        "keyword.operator.typeof",
        "keyword.operator.void",
        "keyword.other.DML.sql",
        "keyword.other.DDL.sql",
        "keyword.other.sql"
      ],
      "settings": { "foreground": "#fa57d7" }
    },
    {
      "name": "Control flow keywords (italic)",
      "scope": ["keyword.control"],
      "settings": { "foreground": "#df8bcd", "fontStyle": "italic" }
    },
    {
      "name": "Storage keywords",
      "scope": ["storage.type", "storage.modifier"],
      "settings": { "foreground": "#fa57d7" }
    },

    // ─── Functions & Methods ─────────────────────────────────────────────────
    {
      "name": "Function declarations",
      "scope": [
        "entity.name.function",
        "entity.name.function.go",
        "meta.definition.method entity.name.function",
        "support.function",
        "support.constant.handlebars",
        "support.function.builtin.shell"
      ],
      "settings": { "foreground": "#fa57d7", "fontStyle": "italic" }
    },
    {
      "name": "SQL aggregate functions",
      "scope": ["support.function.aggregate.sql"],
      "settings": { "foreground": "#fa57d7", "fontStyle": "italic" }
    },

    // ─── Types, Classes, Interfaces ──────────────────────────────────────────
    {
      "name": "Types, classes, interfaces",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "support.class",
        "support.type",
        "meta.return-type",
        "meta.type.cast.expr",
        "meta.type.new.expr",
        "entity.other.inherited-class",
        "support.constant.math",
        "support.constant.dom",
        "support.constant.json",
        "storage.type.numeric.go",
        "storage.type.byte.go",
        "storage.type.boolean.go",
        "storage.type.string.go",
        "storage.type.uintptr.go",
        "storage.type.error.go",
        "storage.type.rune.go",
        "storage.type.cs",
        "storage.type.generic.cs",
        "storage.type.modifier.cs",
        "storage.type.variable.cs",
        "storage.type.annotation.java",
        "storage.type.generic.java",
        "storage.type.java",
        "storage.type.object.array.java",
        "storage.type.primitive.array.java",
        "storage.type.primitive.java",
        "storage.type.token.java",
        "storage.type.groovy",
        "storage.type.annotation.groovy",
        "storage.type.parameters.groovy",
        "storage.type.generic.groovy",
        "storage.type.object.array.groovy",
        "storage.type.primitive.array.groovy",
        "storage.type.primitive.groovy",
        "support.function.builtin.python",
        "meta.function.parameters.annotation.python"
      ],
      "settings": { "foreground": "#56d4e8" }
    },
    {
      "name": "Generic type parameters",
      "scope": [
        "meta.type.parameters",
        "punctuation.definition.typeparameters.begin",
        "punctuation.definition.typeparameters.end"
      ],
      "settings": { "foreground": "#56d4e8" }
    },

    // ─── Variables & Parameters ───────────────────────────────────────────────
    {
      "name": "Variables and parameters",
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable",
        "entity.name.variable",
        "variable.other.readwrite.alias",
        "variable.scss",
        "variable.other.normal.shell"
      ],
      "settings": { "foreground": "#fcf948" }
    },
    {
      "name": "Python self/cls",
      "scope": ["variable.parameter.function.language.special.self.python"],
      "settings": { "foreground": "#6a7a8a" }
    },

    // ─── Constants ────────────────────────────────────────────────────────────
    {
      "name": "Language constants (true, false, null, undefined)",
      "scope": [
        "constant.language",
        "constant.language.json"
      ],
      "settings": { "foreground": "#569cd6" }
    },
    {
      "name": "Numeric literals",
      "scope": [
        "constant.numeric",
        "constant.numeric.css",
        "keyword.other.unit.css"
      ],
      "settings": { "foreground": "#569cd6" }
    },
    {
      "name": "Constant character",
      "scope": "constant.character",
      "settings": { "foreground": "#569cd6" }
    },
    {
      "name": "Escape characters",
      "scope": "constant.character.escape",
      "settings": { "foreground": "#d7ba7d" }
    },

    // ─── Strings ──────────────────────────────────────────────────────────────
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.single",
        "string.quoted.double",
        "string.template"
      ],
      "settings": { "foreground": "#e29c63" }
    },

    // ─── Object / JSON Keys ───────────────────────────────────────────────────
    {
      "name": "Object keys",
      "scope": [
        "meta.object-literal.key",
        "support.type.property-name.json"
      ],
      "settings": { "foreground": "#b791ff" }
    },

    // ─── Decorators ───────────────────────────────────────────────────────────
    {
      "name": "Decorators",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator.python",
        "punctuation.definition.decorator.python"
      ],
      "settings": { "foreground": "#d7ba7d" }
    },

    // ─── Namespaces ───────────────────────────────────────────────────────────
    {
      "name": "Namespaces and modules",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "entity.name.package.go"
      ],
      "settings": { "foreground": "#b791ff" }
    },

    // ─── JSX / TSX ────────────────────────────────────────────────────────────
    {
      "name": "JSX/TSX tag names",
      "scope": [
        "entity.name.tag",
        "entity.name.tag.tsx",
        "entity.name.tag.jsx",
        "entity.name.tag.html",
        "entity.name.tag.css"
      ],
      "settings": { "foreground": "#56d4e8" }
    },
    {
      "name": "JSX/TSX attribute names",
      "scope": [
        "entity.other.attribute-name",
        "entity.other.attribute-name.tsx",
        "entity.other.attribute-name.jsx",
        "entity.other.attribute-name.html"
      ],
      "settings": { "foreground": "#fcf948" }
    },
    {
      "name": "JSX expression containers",
      "scope": ["punctuation.section.embedded"],
      "settings": { "foreground": "#df8bcd" }
    },
    {
      "name": "JSX/HTML tag punctuation",
      "scope": [
        "punctuation.definition.tag",
        "punctuation.definition.tag.begin",
        "punctuation.definition.tag.end"
      ],
      "settings": { "foreground": "#6a7a8a" }
    },

    // ─── CSS / SCSS ───────────────────────────────────────────────────────────
    {
      "name": "CSS property names",
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name.scss",
        "support.type.property-name.less"
      ],
      "settings": { "foreground": "#56d4e8" }
    },
    {
      "name": "CSS property values",
      "scope": [
        "support.constant.property-value",
        "support.constant.font-name",
        "support.constant.media-type",
        "support.constant.media",
        "constant.other.color.rgb-value",
        "constant.other.rgb-value",
        "support.constant.color"
      ],
      "settings": { "foreground": "#e29c63" }
    },
    {
      "name": "CSS selectors",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": { "foreground": "#fa57d7" }
    },
    {
      "name": "CSS at-rules",
      "scope": ["keyword.control.at-rule"],
      "settings": { "foreground": "#fa57d7" }
    },

    // ─── Markdown ─────────────────────────────────────────────────────────────
    {
      "name": "Markdown headings",
      "scope": ["markup.heading", "entity.name.section.markdown"],
      "settings": { "foreground": "#fa57d7", "fontStyle": "bold" }
    },
    {
      "name": "Markdown inline code",
      "scope": ["markup.inline.raw.string.markdown"],
      "settings": { "foreground": "#56d4e8" }
    },
    {
      "name": "Markdown links",
      "scope": ["markup.underline.link", "markup.underline.link.image"],
      "settings": { "foreground": "#56d4e8" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "fontStyle": "italic" }
    },
    {
      "name": "Markdown blockquotes",
      "scope": ["markup.quote"],
      "settings": { "foreground": "#6a7a8a", "fontStyle": "italic" }
    },
    {
      "name": "Markdown fenced code blocks",
      "scope": ["markup.fenced_code.block.markdown"],
      "settings": { "foreground": "#cdd6f4" }
    },

    // ─── Shell ────────────────────────────────────────────────────────────────
    {
      "name": "Shell flags and options",
      "scope": ["string.unquoted.argument.shell"],
      "settings": { "foreground": "#6a7a8a" }
    },
    {
      "name": "Shell string interpolation",
      "scope": ["meta.string-contents.quoted.double.shell"],
      "settings": { "foreground": "#df8bcd" }
    },

    // ─── Regex ────────────────────────────────────────────────────────────────
    {
      "name": "Regular expression groups",
      "scope": [
        "punctuation.definition.group.regexp",
        "punctuation.definition.group.assertion.regexp",
        "punctuation.definition.character-class.regexp",
        "punctuation.character.set.begin.regexp",
        "punctuation.character.set.end.regexp",
        "keyword.operator.negation.regexp",
        "support.other.parenthesis.regexp"
      ],
      "settings": { "foreground": "#d16969" }
    },
    {
      "scope": [
        "constant.character.character-class.regexp",
        "constant.other.character-class.set.regexp",
        "constant.other.character-class.regexp",
        "constant.character.set.regexp"
      ],
      "settings": { "foreground": "#d16969" }
    },
    {
      "scope": ["keyword.operator.or.regexp", "keyword.control.anchor.regexp"],
      "settings": { "foreground": "#DCDCAA" }
    },
    {
      "scope": "keyword.operator.quantifier.regexp",
      "settings": { "foreground": "#d7ba7d" }
    }

  ]
}
